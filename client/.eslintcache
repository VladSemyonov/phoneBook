ixableWarningCount":0,"usedDeprecatedRules":"77"},{"filePath":"100","messages":"101","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"102","usedDeprecatedRules":"77"},"D:\\client\\src\\index.js",[],"D:\\client\\src\\components\\App.js",[],"D:\\client\\src\\components\\HomePage.js",[],"D:\\client\\src\\components\\About.js",[],"D:\\client\\src\\components\\TopNavigation.js",[],"D:\\client\\src\\components\\NumbersPage.js",["103"],"D:\\client\\src\\components\\numbers\\Number.js",[],"D:\\client\\src\\api.js",["104"],"D:\\client\\src\\components\\forms\\NumberForm.js",[],"D:\\client\\src\\components\\numbers\\index.js",[],"D:\\client\\src\\components\\forms\\FormUtils.js",[],"D:\\client\\src\\components\\numbers\\NumberCard.js",["105"],"D:\\PhoneBook\\phoneBook\\client\\src\\index.js",[],["106","107"],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\App.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\HomePage.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\About.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\NumbersPage.js",["108"],"import React, {useState, useEffect} from \"react\"\nimport api from \"../api\"\nimport NumbersList from \"./numbers\"\nimport {AppContext} from './App'\nimport {sortBy, filter} from 'lodash'\nimport NumberForm from \"./forms/NumberForm\";\n\nfunction NumbersPage () {\n\n    const [numbers, setNumbers] = useState()\n    const [searchValue, setSearchValue] = useState('')\n    const [finedContacts, setFinedContacts] = useState()\n    const [editData, setEditData] = useState()\n    const [showAddForm, setShowAddForm] = useState(false)\n\n\n    useEffect(()=>{\n        api.numbers.fetchAll()\n            .then(number=> setNumbers(sortBy(number, [function(i){return i.name.toLowerCase()}])))\n    }, [])\n\n    const deleteNumber = (numberN) =>{\n        api.numbers.delete(numberN)\n        setNumbers(()=>numbers.filter(number=>number._id !== numberN._id))\n     }\n\n    const saveNumbers = number => {\n        (number._id ? updateNumber(number) : addNumber(number))\n        setShowAddForm(false)\n    }\n\n    const addNumber = numberData =>{\n        api.numbers.create(numberData).then(number=>\n                setNumbers([...numbers, {...number}]))\n    }\n\n    const updateNumber = numberData =>{\n        api.numbers.update(numberData).then(number=>\n        setNumbers(numbers.map(item => (item._id === number._id ? number : item)),\n        ))\n        setEditData()}\n\n    const updateFindValue = (e) => {\n        setSearchValue(e.target.value)\n    }\n\n    const toggleForm = (data) =>{\n        setEditData(numbers.filter(item=>item._id === data))\n        setShowAddForm(true)\n        }\n\n     const closeForm = () =>{\n        setEditData()\n         setShowAddForm(false)\n     }\n\n\n    const findContact = () => {\n        setFinedContacts(filter(numbers, (item)=>{\n            if(item.name.toLowerCase().includes(searchValue.toLowerCase()))\n                return item\n            if(item.telephone.toLowerCase().includes(searchValue.toLowerCase()))\n                return item}))\n    }\n\n    const createContact = () =>{\n        setEditData()\n        setShowAddForm(!showAddForm)\n    }\n\n    useEffect(()=>{\n        if(searchValue)findContact()}, [searchValue])\n\n        return (\n            <AppContext.Provider\n                value={{\n                    deleteNumber: deleteNumber,\n                    toggleForm: toggleForm\n                }}>\n                    <div className={'main-content'}>\n                        <div className={'search-div'}>\n                            <h4>Contacts</h4>\n                            <button onClick={createContact}>Create contact</button>\n                            <input className={'search'}\n                                type=\"text\"\n                                onChange={updateFindValue}\n                                value={searchValue}\n                                placeholder='Find contact'\n                            />\n                        </div>\n\n                        {searchValue ?\n                            <NumbersList numbers={finedContacts}/> :\n                            <NumbersList numbers={numbers}/>\n                        }\n                    </div>\n                {showAddForm && <NumberForm click={closeForm} number={editData} submit={saveNumbers} />}\n\n            </AppContext.Provider>\n        )\n    }\n\nexport default NumbersPage\n","D:\\PhoneBook\\phoneBook\\client\\src\\components\\TopNavigation.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\numbers\\Number.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\api.js",["109"],"import axios from 'axios'\n\nexport default {\n    numbers: {\n        fetchAll: () => axios.get(\"/api/numbers\").then(res => res.data.numbers),\n        create: number => axios.post(\"/api/numbers\", number).then(res => res.data.number),\n        update: number => axios.put(`/api/numbers/${number._id}`, {number}).then(res => res.data.number),\n        delete: number => axios.delete(`/api/numbers/${number._id}`),\n    },\n}\n","D:\\PhoneBook\\phoneBook\\client\\src\\components\\forms\\NumberForm.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\numbers\\index.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\forms\\FormUtils.js",[],"D:\\PhoneBook\\phoneBook\\client\\src\\components\\numbers\\NumberCard.js",["110"],"import React, {useContext} from \"react\"\nimport {AppContext} from '../App'\n\nconst NumberCard =({number}) => {\n        const {deleteNumber, toggleForm} = useContext(AppContext)\n\n        return (\n            <div className={'card-container'}>\n            <div className={'card-item'}>\n                <img className={'card-img'} src={number.img} />\n                <div className={'info'}>\n                    <span>{number.name}</span>\n                    <span>{number.telephone}</span>\n                </div>\n                <div className={'card-buttons'}>\n                    <button onClick={() => deleteNumber(number)}>Delete</button>\n                    <button  onClick={()=>toggleForm(number._id)}>Edit</button>\n                </div>\n            </div>\n            </div>\n                )\n}\n\nexport default React.memo(NumberCard)\n",{"ruleId":"111","severity":1,"message":"112","line":72,"column":40,"nodeType":"113","endLine":72,"endColumn":53,"suggestions":"114"},{"ruleId":"115","severity":1,"message":"116","line":3,"column":1,"nodeType":"117","endLine":10,"endColumn":2},{"ruleId":"118","severity":1,"message":"119","line":10,"column":17,"nodeType":"120","endLine":10,"endColumn":64},{"ruleId":"121","replacedBy":"122"},{"ruleId":"123","replacedBy":"124"},{"ruleId":"111","severity":1,"message":"112","line":72,"column":40,"nodeType":"113","endLine":72,"endColumn":53,"suggestions":"125"},{"ruleId":"115","severity":1,"message":"116","line":3,"column":1,"nodeType":"117","endLine":10,"endColumn":2},{"ruleId":"118","severity":1,"message":"119","line":10,"column":17,"nodeType":"120","endLine":10,"endColumn":64},"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'findContact'. Either include it or remove the dependency array.","ArrayExpression",["126"],"import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","no-native-reassign",["127"],"no-negated-in-lhs",["128"],["129"],{"desc":"130","fix":"131"},"no-global-assign","no-unsafe-negation",{"desc":"130","fix":"132"},"Update the dependencies array to be: [findContact, searchValue]",{"range":"133","text":"134"},{"range":"135","text":"134"},[2112,2125],"[findContact, searchValue]",[2112,2125]]